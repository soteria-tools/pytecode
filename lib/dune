(library
 (name pytecode)
 (public_name pytecode)
 (libraries unix yojson zarith fmt)
 (preprocess
  (pps ppx_opcode ppx_deriving.std)))

; dump_bytecode.py embedded as an OCaml string. Always generated (it only
; needs `cat`), so it can never go stale relative to tools/.

(rule
 (target dump_script.ml)
 (deps ../tools/dump_bytecode.py)
 (action
  (with-stdout-to
   %{target}
   (progn
    (echo
     "(* Embedded tools/dump_bytecode.py -- generated at build time, do not edit. *)\n")
    (echo "let source = {pytecode_dump|")
    (cat ../tools/dump_bytecode.py)
    (echo "|pytecode_dump}\n")))))

; Opcode tables are generated from the pinned CPython and checked in, so plain
; builds never need Python. `dune build @gen` re-runs the generator and fails
; on drift; `dune promote` then updates the checked-in files.

(rule
 (targets opcode.ml.raw opcode.mli.raw)
 (deps ../tools/gen_opcodes.py)
 (action
  (run
   python3.13
   ../tools/gen_opcodes.py
   --ml
   opcode.ml.raw
   --mli
   opcode.mli.raw)))

; The generator output is formatted like any other source, so the checked-in
; files stay ocamlformat-clean and the diff rules compare like with like.

(rule
 (target opcode.ml.gen)
 (deps ../.ocamlformat)
 (action
  (with-stdout-to
   %{target}
   (run ocamlformat --impl --name opcode.ml %{dep:opcode.ml.raw}))))

(rule
 (target opcode.mli.gen)
 (deps ../.ocamlformat)
 (action
  (with-stdout-to
   %{target}
   (run ocamlformat --intf --name opcode.mli %{dep:opcode.mli.raw}))))

(rule
 (alias gen)
 (action
  (diff opcode.ml opcode.ml.gen)))

(rule
 (alias gen)
 (action
  (diff opcode.mli opcode.mli.gen)))
